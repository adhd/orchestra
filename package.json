{
  "name": "orchestra",
  "version": "0.1.0",
  "description": "Autonomous work orchestration for Claude Code — Symphony-compatible",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "orchestra": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run test/integration",
    "test:e2e": "vitest run test/e2e",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-code": "^0.2.76",
    "commander": "^12.1.0",
    "fastify": "^5.2.1",
    "gray-matter": "^4.0.3",
    "liquidjs": "^10.21.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "msw": "^2.7.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
